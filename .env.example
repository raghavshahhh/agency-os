# RAGSPRO Agency OS - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# NVIDIA NIM (Qwen AI) - Get from: https://build.nvidia.com/explore
NVIDIA_API_KEY=

# Telegram Bot - Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Gmail SMTP - Generate App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Search APIs (optional)
SERPAPI_KEY=
TAVILY_API_KEY=

# n8n Integration (optional)
N8N_API_KEY=
N8N_URL=http://localhost:5678

# Email Service (optional - alternative to Gmail)
RESEND_API_KEY=

# Google Sheets Integration (optional)
GOOGLE_SHEET_ID=

# Lead Enrichment APIs (Free tiers - highly recommended!)
# Hunter.io - Get API key: https://hunter.io/api
# Free: 50 requests/month, 1/sec rate limit
HUNTER_API_KEY=

# Apollo.io - Get API key: https://apollo.io/integrations
# Free: 50 credits/month, great for B2B email enrichment
APOLLO_API_KEY=

# Clearbit (optional) - Get API key: https://clearbit.com/
# Free: 20 requests/month, company data enrichment
CLEARBIT_API_KEY=
